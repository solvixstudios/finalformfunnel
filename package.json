    "build-plugin-wc": "node scripts/build-plugin-wc.js",
    "deploy-dev": "npm run build-dev && firebase deploy --project finalformfunnel-beta",
    "deploy-prod": "npm run build-prod && firebase deploy --project finalformfunnel",
    "lint": "eslint .",
    "preview": "vite preview",
