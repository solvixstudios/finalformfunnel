# Firebase Configuration
# Get these values from your Firebase project settings (https://console.firebase.google.com/)
# Go to Project Settings -> Your apps -> Web app configuration

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# n8n Backend Configuration
# URL of your n8n instance that handles Shopify OAuth verification
VITE_N8N_BACKEND_URL=https://your-n8n-instance.com

# Encryption Key
# Used to encrypt sensitive data (Client ID/Secret) before sending to backend
# Generate a secure 32-character key for production
VITE_ENCRYPTION_KEY=your-32-character-encryption-key
