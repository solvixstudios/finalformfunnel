      "id": "delete-script",
      "name": "Delete Loader Script",
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { success: true, removed: true, message: 'Loader disabled successfully!' } }];"
      },
      "type": "n8n-nodes-base.code",
