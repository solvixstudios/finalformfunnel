            "id": "f48d4c4b-95a8-423c-98d9-c19586e14abb",
            "name": "Get Product Configs",
            "alwaysOutputData": true
        },
        {
            "parameters": {
                "jsCode": "// Build assignments list from both tables\nconst storeData = $('Verify Store').first().json;\nconst storeId = storeData.storeId;\n\nconst storeConfigs = $('Get Store Configs').all();\nconst productConfigs = $('Get Product Configs').all();\n\nconst assignments = [];\n\n// Global store assignment\nconst storeConfig = storeConfigs.find(r => r.json.storeId === storeId);\nif (storeConfig) {\n  assignments.push({\n    type: 'store',\n    formId: storeConfig.json.formId,\n    storeId: storeId\n  });\n}\n\n// Product-level assignments\nproductConfigs\n  .filter(r => r.json.storeId === storeId)\n  .forEach(r => {\n    assignments.push({\n      type: 'product',\n      formId: r.json.formId,\n      productId: r.json.productId,\n      storeId: storeId\n    });\n  });\n\nreturn [{ json: { success: true, assignments } }];"
            },
