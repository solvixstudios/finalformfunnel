            "id": "a9a82d1f-ee81-43d4-b6a2-242395d86f06",
            "name": "Get Store Configs",
            "alwaysOutputData": true
        },
        {
            "parameters": {
                "operation": "get",
                "dataTableId": {
                    "__rl": true,
                    "value": "product_configs",
                    "mode": "name"
                }
            },
            "type": "n8n-nodes-base.dataTable",
            "typeVersion": 1.1,
