    },
    {
      "parameters": {
        "jsCode": "// Parse request body\nconst body = $input.first().json.body;\n\nconst shopDomain = body.shopDomain;\nconst clientId = body.clientId;\nconst clientSecret = body.clientSecret;\n\n// Use productId (new) or ownerId (legacy fallback)\nlet productId = body.productId || body.ownerId || '';\nif (!productId || productId === 'null' || productId === 'undefined') {\n  productId = '';\n} else {\n  productId = String(productId).trim();\n  // Strip GID prefix if present (backwards compat)\n  const gidMatch = productId.match(/^gid:\\/\\/shopify\\/Product\\/(.+)$/);\n  if (gidMatch) productId = gidMatch[1];\n}\n\nif (!shopDomain || !clientId || !clientSecret) {\n  return [{ json: { error: 'Missing required credentials', valid: false } }];\n}\n\n// Determine target table\nconst isProductLevel = productId !== '';\n\nreturn [{ json: {\n  valid: true,\n  shopDomain,\n  clientId,\n  clientSecret,\n  productId,\n  isProductLevel\n} }];"
      },
      "type": "n8n-nodes-base.code",
