        "jsCode": "// Find product config to delete\nconst rows = $input.all();\nconst verifyData = $('Verify Store').first().json;\nconst storeId = verifyData.storeId;\nconst productId = verifyData.productId;\n\nconst config = rows.find(r =>\n  r.json.storeId === storeId && r.json.productId === productId\n);\n\nif (config) {\n  return [{ json: { found: true, id: config.json.id, storeId, productId } }];\n}\n\nreturn [{ json: { found: false } }];"
