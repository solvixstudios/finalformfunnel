      "typeVersion": 2.2,
      "position": [1920, -200],
      "id": "if-config-found",
      "name": "If Config Found"
    },
    {
      "parameters": {
        "operation": "deleteRow",
        "dataTableId": {
          "__rl": true,
          "value": "store_configs",
          "mode": "name"
        },
        "deleteByFilterColumn": {
          "mappingMode": "defineBelow",
          "value": {
            "storeId": "={{ $json.storeId }}",
            "ownerId": "={{ $json.ownerId }}"
          }
        }
      },
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [2160, -300],
      "id": "delete-config",
      "name": "Delete Config"
    },
