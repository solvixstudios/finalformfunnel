      "webhookId": "shopify-disconnect-webhook"
    },
    {
      "parameters": {
        "jsCode": "// Parse disconnect request\nconst body = $input.first().json.body;\n\nif (!body.shopDomain) {\n  return [{ json: { valid: false, error: 'shopDomain is required' } }];\n}\n\nreturn [{\n  json: {\n    valid: true,\n    shopDomain: body.shopDomain\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        0
      ],
      "id": "parse-request",
      "name": "Parse Request"
    },
