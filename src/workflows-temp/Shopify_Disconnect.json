      "id": "get-row",
      "name": "Get row(s)",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Find the row to delete\nconst rows = $input.all();\nconst shopDomain = $('Parse Request').first().json.shopDomain;\n\nconst row = rows.find(r => r.json.shopDomain === shopDomain);\n\nif (row) {\n  return [{ json: { found: true, rowId: row.json.id, shopDomain } }];\n}\n\nreturn [{ json: { found: false, shopDomain } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1680,
        -200
      ],
      "id": "find-row",
      "name": "Find Row"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "row-exists",
              "leftValue": "={{ $json.found }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
