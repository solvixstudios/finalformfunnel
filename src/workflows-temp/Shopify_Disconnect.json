      "parameters": {
        "jsCode": "// Parse disconnect request\nconst body = $input.first().json.body;\n\n// normalize shop domain\nlet shopDomain = body.shopDomain || '';\nif (shopDomain && !shopDomain.includes('.')) {\n  shopDomain += '.myshopify.com';\n}\n\nif (!shopDomain) {\n  return [{ json: { valid: false, error: 'shopDomain is required' } }];\n}\n\nreturn [{\n  json: {\n    valid: true,\n    shopDomain: shopDomain\n  }\n}];"
      },
