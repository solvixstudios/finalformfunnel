{
  "name": "Shopify Disconnect",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "shopify/disconnect",
        "responseMode": "responseNode",
        "options": {
          "allowedOrigins": "*"
        }
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
