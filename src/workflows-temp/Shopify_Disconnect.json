    {
      "parameters": {
        "jsCode": "// Error response\nconst error = $input.first().json.error || 'Invalid request';\nreturn [{\n  json: {\n    success: false,\n    error: error\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2400,
        100
      ],
      "id": "error-response",
