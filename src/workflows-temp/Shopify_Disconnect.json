      "parameters": {
        "jsCode": "// Find the row to delete\nconst rows = $input.all();\nconst shopDomain = $('Parse Request').first().json.shopDomain;\n\nconst row = rows.find(r => r.json.shopDomain === shopDomain);\n\nif (row) {\n  return [{ json: { found: true, rowId: row.id, storeId: row.json.storeId, shopDomain } }];\n}\n\nreturn [{ json: { found: false, shopDomain } }];"
