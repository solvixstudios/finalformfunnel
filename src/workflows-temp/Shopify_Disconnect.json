    {
      "parameters": {
        "jsCode": "// Find all store_configs rows matching the storeId being disconnected\nconst rows = $input.all();\nconst storeId = $('Find Row').first().json.storeId;\n\nif (!storeId) {\n  return [{ json: { configsFound: false, count: 0 } }];\n}\n\nconst matching = rows.filter(r => r.json.storeId === storeId);\n\nif (matching.length === 0) {\n  return [{ json: { configsFound: false, count: 0 } }];\n}\n\n// Return each matching row ID for deletion\nreturn matching.map(r => ({ json: { configsFound: true, configRowId: r.id, storeId } }));"
      },
