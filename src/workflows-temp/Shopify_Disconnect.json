          "__rl": true,
          "value": "stores",
          "mode": "name"
        },
        "rowId": "={{ $json.rowId }}",
        "options": {}
      },
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [
        2160,
        -300
      ],
      "id": "delete-row",
      "name": "Delete row"
    },
    {
      "parameters": {
        "jsCode": "// Success response\nreturn [{\n  json: {\n    success: true,\n    message: 'Store credentials removed successfully'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2400,
