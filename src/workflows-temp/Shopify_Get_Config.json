      "id": "ed9bce19-0354-4c3f-8e77-0daf667344a4",
      "name": "Get Configs",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Find config with fallback: product -> store-level\nconst rows = $input.all();\nconst storeData = $('Find Store').first().json;\n\nconst storeId = storeData.storeId;\nconst productId = storeData.productId;\n\n// Normalize ownerId: productId or empty string for store-level\nconst normalizeOwnerId = (id) => (!id || id === 'null' || id === 'undefined') ? '' : String(id);\n\n// First try to find product-specific config\nlet config = null;\nif (productId) {\n  const targetOwnerId = normalizeOwnerId(productId);\n  config = rows.find(r => {\n    const rowOwnerId = normalizeOwnerId(r.json.ownerId);\n    return r.json.storeId === storeId && rowOwnerId === targetOwnerId;\n  });\n}\n\n// Fallback to store-level config (ownerId is empty string)\nif (!config) {\n  config = rows.find(r => {\n    const rowOwnerId = normalizeOwnerId(r.json.ownerId);\n    return r.json.storeId === storeId && rowOwnerId === '';\n  });\n}\n\nif (config) {\n  let formData = {};\n  try {\n    if (config.json.formData) {\n      if (typeof config.json.formData === 'string') {\n        formData = JSON.parse(config.json.formData);\n      } else {\n        formData = config.json.formData;\n      }\n    }\n  } catch (e) {\n    formData = {};\n  }\n  return [{ json: {\n    found: true,\n    formId: config.json.formId,\n    formData,\n    updatedAt: config.json.updatedAt || new Date().toISOString(),\n    ownerId: config.json.ownerId,\n    isProductLevel: !!(productId && normalizeOwnerId(config.json.ownerId) === normalizeOwnerId(productId))\n  } }];\n}\n\nreturn [{ json: { found: false, formData: {} } }];"
      },
