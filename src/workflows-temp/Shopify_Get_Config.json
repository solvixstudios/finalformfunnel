    {
      "parameters": {
        "jsCode": "// Parse query params\nconst query = $input.first().json.query;\n\nconst shopDomain = query.shop;\nconst productId = query.productId || null;\n\nif (!shopDomain) {\n  return [{ json: { valid: false, error: 'Missing shop parameter' } }];\n}\n\nreturn [{ json: {\n  valid: true,\n  shopDomain,\n  productId\n} }];"
      },
