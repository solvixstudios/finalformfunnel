      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [400, 576],
      "id": "769166dd-373e-49b5-bce3-f882e479ade2",
      "name": "Respond"
    },
    {
      "parameters": {
        "jsCode": "// Format error response with proper JSON structure\nconst errors = $input.first().json.errors || ['Unknown error'];\n\nreturn [{\n  json: {\n    success: false,\n    errors: errors\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
