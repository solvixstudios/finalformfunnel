      "webhookId": "master-sync-webhook"
    },
    {
      "parameters": {
        "jsCode": "// Parse request and build shop domain\nconst body = $input.first().json.body;\nconst subdomain = body.subdomain;\nconst shopDomain = subdomain + '.myshopify.com';\nconst action = body.action || 'save';\nconst ownerId = body.ownerId;\nconst configData = body.data;\nconst clientId = body.clientId;\nconst clientSecret = body.clientSecret;\n\nreturn [{ json: { \n  subdomain, \n  shopDomain,\n  action,\n  ownerId,\n  configData,\n  clientId,\n  clientSecret\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -10320,
        2288
      ],
      "id": "bad90c47-9d7b-4027-90ef-6ecf5352d0bf",
