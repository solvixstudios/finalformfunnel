      "id": "d91f33fc-02b4-451a-ab7b-5611531d4f9b",
      "name": "Get Store Credentials",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Find matching store and verify credentials\nconst rows = $input.all();\nconst req = $('Parse Request').first().json;\n\nconst store = rows.find(r => r.json.shopDomain === req.shopDomain);\n\nif (store) {\n  const storedClientId = store.json.clientId;\n  const storedClientSecret = store.json.clientSecret;\n  \n  // Strict Credential Check\n  if (storedClientId === req.clientId && storedClientSecret === req.clientSecret) {\n    return [{ json: { \n      found: true, \n      rowId: store.id,\n      config: store.json.config,\n      subdomain: req.subdomain, \n      accessToken: store.json.accessToken,\n      action: req.action,\n      ownerId: req.ownerId,\n      configData: req.configData\n    } }];\n  }\n}\n\nreturn [{ json: { found: false, subdomain: req.subdomain, error: 'Invalid credentials or store not found' } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -9120,
        2192
      ],
      "id": "91cc8dff-40f6-4d94-abd1-926b4f967c71",
      "name": "Find Store"
    },
