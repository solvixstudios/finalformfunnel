    {
      "parameters": {
        "jsCode": "// Check if store already exists\nconst rows = $input.all();\nconst req = $('Receive Connect Request').first().json.body;\nconst shopDomain = $('Format Success Response').first().json.storeData.shopDomain;\nconst currentUserId = req.userId;\n\nconst existingRow = rows.find(row => row.json.shopDomain === shopDomain);\n\nif (existingRow) {\n  const rowUserId = existingRow.json.userId;\n  const storeId = existingRow.json.storeId;\n  // Enforce ownership: If row has userId and it doesn't match current request -> Error\n  if (rowUserId && currentUserId && rowUserId !== currentUserId) {\n     return [{ json: { error: 'Store already connected to another account', exists: true, accessDenied: true } }];\n  }\n  return [{ json: { exists: true, rowId: existingRow.json.id, storeId: storeId, shopDomain, userId: currentUserId } }];\n}\n\nreturn [{ json: { exists: false, shopDomain, userId: currentUserId } }];"
      },
