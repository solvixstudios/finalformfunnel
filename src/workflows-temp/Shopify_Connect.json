    {
      "parameters": {
        "jsCode": "// Build the success response with proper JSON structure\n// After Crypto node, we need .first().json to access upstream nodes\nconst shopData = $('Get Shop Details').first().json.shop;\nconst accessToken = $('Get Access Token').first().json.access_token;\nconst scriptTags = $('Check Existing ScriptTags').first().json.script_tags || [];\n\n// Prepare data for storage\nconst subdomain = $('Receive Connect Request').first().json.body.subdomain;\nconst clientId = $('Receive Connect Request').first().json.body.clientId;\nconst clientSecret = $('Receive Connect Request').first().json.body.clientSecret;\n\n// Use the UUID generated by the Crypto node (output is in 'data' field)\nconst storeId = $('Crypto').first().json.data;\n\n// Find FinalForm loader script tag\nconst loaderTag = scriptTags.find(t => \n  t.src && (t.src.includes('finalform'))\n);\n\nconst loaderInstalled = !!loaderTag;\n\n// Extract version from URL if present\nlet loaderVersion = null;\nif (loaderTag && loaderTag.src) {\n  const versionMatch = loaderTag.src.match(/[?&]v(?:ersion)?=([0-9]+\\.[0-9]+\\.[0-9]+)/);\n  if (versionMatch) {\n    loaderVersion = versionMatch[1];\n  }\n}\n\nreturn [{\n  json: {\n    success: true,\n    shop: shopData,\n    loaderInstalled: loaderInstalled,\n    loaderVersion: loaderVersion,\n    loaderScriptTagId: loaderTag ? loaderTag.id.toString() : null,\n    accessToken: accessToken,\n    // Store data for data table\n    storeData: {\n      storeId: storeId, // UUID from Crypto node\n      shopDomain: subdomain + '.myshopify.com',\n      subdomain: subdomain,\n      clientId: clientId,\n      clientSecret: clientSecret,\n      accessToken: accessToken,\n      shopName: shopData?.name || subdomain,\n      createdAt: new Date().toISOString()\n    }\n  }\n}];"
      },
