    {
      "parameters": {
        "jsCode": "// Prepare row data for update\nconst storeData = $('Format Success Response').first().json.storeData;\nconst rowExistsData = $('If row exists').first().json;\nconst rowId = rowExistsData.rowId;\nconst userId = rowExistsData.userId;\n\nreturn [{\n  json: {\n    id: rowId,\n    accessToken: storeData.accessToken,\n    shopName: storeData.shopName,\n    updatedAt: new Date().toISOString(),\n    ...(userId ? { userId } : {}) // Update userId if provided (claim ownership if empty? or just consistency)\n  }\n}];"
