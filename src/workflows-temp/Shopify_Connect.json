    {
      "parameters": {
        "jsCode": "// Return final success response\nconst responseData = $('Format Success Response').first().json;\n\n// Safely check if Check Row Exists was executed (only when table existed)\nlet existingRow = null;\ntry {\n  existingRow = $('Check Row Exists').first().json;\n} catch (e) {\n  // Node wasn't executed (new table was created)\n  existingRow = null;\n}\n\n// If row existed and has storeId, use it; otherwise use the newly generated one\nconst finalStoreId = (existingRow && existingRow.exists && existingRow.storeId)\n  ? existingRow.storeId\n  : responseData.storeData.storeId;\n\nreturn [{\n  json: {\n    success: responseData.success,\n    storeId: finalStoreId,\n    shop: responseData.shop,\n    loaderInstalled: responseData.loaderInstalled,\n    loaderVersion: responseData.loaderVersion,\n    loaderScriptTagId: responseData.loaderScriptTagId,\n    accessToken: responseData.accessToken,\n    credentialsStored: true\n  }\n}];"
