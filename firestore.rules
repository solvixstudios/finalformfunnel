rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document/path
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to check if user is the platform admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'solvixalgerie@gmail.com';
    }

    // New structure: collections nested under users/{userId}
    match /users/{userId} {
      // Allow read/write to the user document itself
      allow read, write: if isOwner(userId);
      
      // Forms collection - public read for loader
      match /forms/{formId} {
        allow read: if true;
        allow create, update, delete: if isOwner(userId);
      }
      
      // Stores collection
      match /stores/{storeId} {
        allow read, write: if isOwner(userId);
      }
      
      // Assignments collection - public read for loader
      match /assignments/{assignmentId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
      
      // Orders collection - allow public create for loader submissions!
      match /orders/{orderId} {
        allow create: if true;
        allow read, update, delete: if isOwner(userId);
      }

      // Products collection
      match /products/{productId} {
        allow read, write: if isOwner(userId);
      }

      // Integration Profiles
      match /whatsapp_profiles/{profileId} {
        allow read, write: if isOwner(userId);
      }

      match /google_sheets/{sheetId} {
        allow read, write: if isOwner(userId);
      }

      match /meta_pixels/{pixelId} {
        allow read, write: if isOwner(userId);
      }

      match /tiktok_pixels/{pixelId} {
        allow read, write: if isOwner(userId);
      }

      // Rule Profiles (Offers, Shipping, Coupons)
      match /offerRules/{ruleId} {
        allow read, write: if isOwner(userId);
      }

      match /shippingRules/{ruleId} {
        allow read, write: if isOwner(userId);
      }

      match /couponRules/{ruleId} {
        allow read, write: if isOwner(userId);
      }

      // Survey responses (onboarding, NPS, feedback, etc.)
      match /surveys/{surveyId} {
        allow read, write: if isOwner(userId);
      }

      // Subscriptions — owner can read, admin can read/write
      match /subscriptions/{subId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
        // Allow the owner to create a pending subscription
        allow create: if isOwner(userId) && request.resource.data.status == 'pending';
      }
    }
    
    // Support for collectionGroup queries used in the loader
    match /{path=**}/forms/{formId} {
      allow read: if true;
    }
    match /{path=**}/assignments/{assignmentId} {
      allow read: if true;
    }

    // Subscription requests — root collection for admin queries
    match /subscription_requests/{requestId} {
      // Users can create their own requests
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Users can read their own requests
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // Only admin can update/delete (approve/reject)
      allow update, delete: if isAdmin();
      // Allow admin to list all requests
      allow list: if isAdmin();
    }

    // Store owners root collection
    match /storeOwners/{domain} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Backward compatibility for root collections (in case loader/sync still uses them)
    match /forms/{formId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && isOwner(resource.data.userId);
    }
    
    match /stores/{storeId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && isOwner(resource.data.userId);
    }
    
    match /assignments/{assignmentId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && isOwner(resource.data.userId);
    }
    
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated() && isOwner(resource.data.userId);
    }
    
    // Global admin settings (plans, payment methods, etc)
    match /admin_settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
  }
}
